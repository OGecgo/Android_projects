<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MainPage">
        <item name="android:background">?attr/background</item>
    </style>
    <style name="DefaultButton">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorPrimaryVariant</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="DefaultTextView">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="DefaultEditText">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="android:textSize">17sp</item>
    </style>
    <style name="ErrorText">
        <item name="android:textColor">?attr/colorSecondaryVariant</item>
        <item name="android:text">center</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="HeaderText">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">21sp</item>
    </style>

    <!-- top view menu -->
    <style name="Button_LogoTopMenu">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorPrimaryVariant</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">22sp</item>
    </style>
    <style name="Button_NameTopMenu">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorPrimaryVariant</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="TopMenu">
        <item name="android:background">?attr/colorPrimary</item>
    </style>


</resources>