<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MainPage">
        <item name="android:background">?attr/backgroundColor</item>
    </style>
    <style name="DefaultButton">
        <item name="android:background">?attr/primaryColor</item>
        <item name="android:textColor">?attr/textColorReverse</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="DefaultTextView">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="DefaultEditText">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:backgroundTint">?attr/primaryColor</item>
        <item name="android:textSize">17sp</item>
    </style>
    <style name="ErrorText">
        <item name="android:textColor">?attr/textErrorColor</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="SuccessText">
        <item name="android:textColor">?attr/textSuccessColor</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="HeaderText">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">24sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="LargeText">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">21sp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ReloadButton">
        <item name="backgroundTint">?attr/textColor</item>
        <item name="tint">?attr/textColorReverse</item>
    </style>

    <style name="ViewLineColor">
        <item name="android:background">?attr/primaryColor</item>
    </style>

    <!-- top view menu -->
    <style name="Button_LogoTopMenu">
        <item name="android:background">?attr/primaryColor</item>
        <item name="android:textColor">?attr/textColorReverse</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">22sp</item>
    </style>
    <style name="Button_NameTopMenu">
        <item name="android:background">?attr/primaryColor</item>
        <item name="android:textColor">?attr/textColorReverse</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="TopMenu">
        <item name="android:background">?attr/primaryColor</item>
    </style>


</resources>