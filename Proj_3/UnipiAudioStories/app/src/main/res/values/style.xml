<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Background">
        <item name="android:background">?attr/backgroundColor</item>
    </style>
    <style name="BackgroundReverse">
        <item name="android:background">?attr/primaryColor</item>
    </style>

    <style name="Button">
        <item name="android:background">?attr/primaryColor</item>
        <item name="android:textColor">?attr/textColorReverse</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="ButtonReverse">
        <item name="android:background">?attr/backgroundColor</item>
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ImageButton">
        <item name="backgroundTint">?attr/primaryColor</item>
        <item name="tint">?attr/textColorReverse</item>
    </style>
    <style name="ImageButtonReverse">
        <item name="backgroundTint">?attr/backgroundColor</item>
        <item name="tint">?attr/textColor</item>
    </style>

    <style name="ViewLineColor">
        <item name="android:background">?attr/primaryColor</item>
    </style>
    <style name="ViewLineColorReverse">
        <item name="android:background">?attr/backgroundColor</item>
    </style>

    <style name="Text">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="TextReverse">
        <item name="android:textColor">?attr/textColorReverse</item>
        <item name="android:textSize">14sp</item>
    </style>    <style name="ErrorText">
        <item name="android:textColor">?attr/textErrorColor</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="SuccessText">
        <item name="android:textColor">?attr/textSuccessColor</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="TitleText">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">30sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="HeaderText">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">24sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="LargeText">
        <item name="android:textColor">?attr/textColor</item>
        <item name="android:textSize">21sp</item>
        <item name="android:gravity">center</item>
    </style>

</resources>